# Required
OPENAI_API_KEY=sk-...

# Optional model overrides
EMBED_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# Report source (default is Kings Research)
REPORTS_SITEMAP=https://www.kingsresearch.com/sitemap-reports.xml

# Verification providers (leave blank to skip — status will be "unknown")
# SERP API for the boolean employment check (SerpAPI / Serper / Bing / Google CSE)
SERPAPI_KEY=
# Optional corporate-email deliverability signal (ZeroBounce / NeverBounce / Hunter)
EMAIL_VERIFY_KEY=
