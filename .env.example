# Required
OPENAI_API_KEY=sk-...
# Optional model overrides
EMBED_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# Research each PERSON on the web (like a manual ChatGPT lookup) before matching.
# Uses OpenAI's search model on this same OPENAI_API_KEY. Off by default because
# the web-search tool adds a per-query fee (~$25 / 1,000 prospects) on top of tokens.
# Set to 1 to enable.
PERSON_WEB_RESEARCH=0
# Which search-enabled model to use for that lookup.
PERSON_SEARCH_MODEL=gpt-4o-mini-search-preview

# Report source (default is Kings Research)
REPORTS_SITEMAP=https://www.kingsresearch.com/sitemap-reports.xml

# Verification providers (leave blank to skip — status will be "unknown")
# SERP API for the boolean employment check (SerpAPI / Serper / Bing / Google CSE)
SERPAPI_KEY=
# Optional corporate-email deliverability signal (ZeroBounce / NeverBounce / Hunter)
EMAIL_VERIFY_KEY=
